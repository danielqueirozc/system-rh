// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  @@map("users")
}

model Service {
  id          Int    @id @default(autoincrement())
  name        String
  description String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments Appointment[]     @relation("appointmentService")
  employee     EmployeeService[]
  budgets      Budget[]          @relation("budgetService")

  @@map("services")
}

enum Status {
  ACTIVE
  INACTIVE
}

model Client {
  id      String @id @default(uuid())
  name    String
  email   String @unique
  phone   String @unique
  address String
  status  Status

  appointments Appointment[] @relation("appointmentClient")
  budgets      Budget[]      @relation("budgetClient")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("clients")
}

enum AppointmentStatus {
  CONFIRMED
  IN_PROGRESS
  PENDING
  COMPLETED
}

model Appointment {
  id String @id @default(uuid())

  client   Client @relation("appointmentClient", fields: [clientId], references: [id])
  clientId String

  service   Service @relation("appointmentService", fields: [serviceId], references: [id])
  serviceId Int

  employee   Employee? @relation("employeeAppointment", fields: [employeeId], references: [id])
  employeeId String?

  status      AppointmentStatus
  serviceDate DateTime

  description String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("appointments")
}

enum EmployeeStatus {
  ACTIVE
  VACATION
  INACTIVE
}

model Employee {
  id       String         @id @default(uuid())
  name     String
  function String
  status   EmployeeStatus
  email    String         @unique
  phone    String         @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employeeServices EmployeeService[]
  appointment      Appointment[]     @relation("employeeAppointment")

  @@map("employees")
}

model EmployeeService {
  employee   Employee @relation(fields: [employeeId], references: [id])
  employeeId String
  service    Service  @relation(fields: [serviceId], references: [id])
  serviceId  Int

  @@id([employeeId, serviceId])
  @@map("employee_services")
}

enum BudgetStatus {
  PENDING
  APPROVED
  REJECTED
}

model Budget {
  id          Int          @id @default(autoincrement())
  description String
  value       Decimal      @db.Decimal(10, 2)
  date        DateTime
  status      BudgetStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client   Client @relation("budgetClient", fields: [clientId], references: [id])
  clientId String

  service   Service @relation("budgetService", fields: [serviceId], references: [id])
  serviceId Int

  @@map("budgets")
}
